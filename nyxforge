#!/usr/bin/env bash
# nyxforge — manage the NyxForge node and Flutter UI
#
# Usage:
#   ./nyxforge [ACTION] [OPTIONS]
#
# Actions:
#   --start         Build and start node + Flutter UI (default if no action given)
#   --stop          Stop all running NyxForge processes
#   --help          Show this message and exit
#
# Options (for --start):
#   --mine              Start mining immediately at launch
#   --threads <n>       CPU threads for mining (default: 1)
#   --mainnet           Use mainnet instead of testnet
#   --no-browser        Don't open Chrome automatically
#
# Modifiers:
#   --dryrun            Show what would be done without doing it
#
# Examples:
#   ./nyxforge                            # start on testnet
#   ./nyxforge --start --mine --threads 4
#   ./nyxforge --stop
#   ./nyxforge --stop --dryrun
#   ./nyxforge --start --mainnet --dryrun

set -euo pipefail

# ---------------------------------------------------------------------------
# Colours
# ---------------------------------------------------------------------------
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info()    { echo -e "${CYAN}[nyxforge]${RESET} $*"; }
success() { echo -e "${GREEN}[nyxforge]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[nyxforge]${RESET} $*"; }
die()     { echo -e "${RED}[nyxforge] ERROR:${RESET} $*" >&2; exit 1; }
dry()     { echo -e "${YELLOW}[dryrun]${RESET}   $*"; }

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
export PATH="$HOME/.cargo/bin:$HOME/development/flutter/bin:$PATH"
FLUTTER="${FLUTTER:-$HOME/development/flutter/bin/flutter}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NODE_BIN="$SCRIPT_DIR/target/debug/nyxforge-node"
NODE_LOG="$SCRIPT_DIR/node.log"
NODE_PID_FILE="$SCRIPT_DIR/node.pid"
FLUTTER_PID_FILE="$SCRIPT_DIR/flutter.pid"
RPC_URL="http://127.0.0.1:8888/rpc"
UI_PORT=8080

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
ACTION=""
DRYRUN=false
MINE=false
THREADS=1
MAINNET=false
OPEN_BROWSER=true

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------
usage() {
    # Print the header comment block at the top of the file, stopping at the
    # first line that isn't a comment (i.e. the first real code line).
    awk '/^[^#]/ && NR > 1 { exit } /^#!/ { next } { sub(/^# ?/, ""); print }' \
        "${BASH_SOURCE[0]}"
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --start)      ACTION=start ;;
        --stop)       ACTION=stop ;;
        --help|-h)    usage ;;
        --dryrun)     DRYRUN=true ;;
        --mine)       MINE=true ;;
        --mainnet)    MAINNET=true ;;
        --threads)
            [[ $# -ge 2 ]] || die "--threads requires a value"
            THREADS="$2"; shift ;;
        --no-browser) OPEN_BROWSER=false ;;
        *) die "Unknown option: $1  (run with --help for usage)" ;;
    esac
    shift
done

# Default action is --start
[[ -z "$ACTION" ]] && ACTION=start

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Run or describe a command based on --dryrun.
run() {
    if [[ "$DRYRUN" == true ]]; then
        dry "$*"
    else
        "$@"
    fi
}

pid_alive() {
    local pid="$1"
    kill -0 "$pid" 2>/dev/null
}

read_pid_file() {
    local file="$1"
    [[ -f "$file" ]] && cat "$file" || true
}

stop_pid() {
    local name="$1"
    local pid_file="$2"
    local pid
    pid="$(read_pid_file "$pid_file")"

    if [[ -z "$pid" ]]; then
        info "$name: no PID file found, checking by name..."
        pid="$(pgrep -x "$name" 2>/dev/null || true)"
    fi

    if [[ -z "$pid" ]]; then
        info "$name: not running"
        return
    fi

    if ! pid_alive "$pid"; then
        info "$name (PID $pid): already stopped"
        [[ "$DRYRUN" == false ]] && rm -f "$pid_file"
        return
    fi

    if [[ "$DRYRUN" == true ]]; then
        dry "kill $name (PID $pid)"
        return
    fi

    info "Stopping $name (PID $pid)..."
    kill "$pid" 2>/dev/null || true

    # Wait up to 5 s for graceful exit, then SIGKILL.
    for _ in $(seq 1 10); do
        pid_alive "$pid" || break
        sleep 0.5
    done
    if pid_alive "$pid"; then
        warn "$name did not exit — sending SIGKILL"
        kill -9 "$pid" 2>/dev/null || true
    fi

    rm -f "$pid_file"
    success "$name stopped"
}

# ---------------------------------------------------------------------------
# STOP
# ---------------------------------------------------------------------------
do_stop() {
    echo ""
    info "Stopping NyxForge..."
    [[ "$DRYRUN" == true ]] && warn "Dry run — nothing will be killed"

    stop_pid "nyxforge-node" "$NODE_PID_FILE"

    # Flutter's process name varies; use PID file first, fall back to port.
    local flutter_pid
    flutter_pid="$(read_pid_file "$FLUTTER_PID_FILE")"

    if [[ -n "$flutter_pid" ]] && pid_alive "$flutter_pid"; then
        if [[ "$DRYRUN" == true ]]; then
            dry "kill flutter (PID $flutter_pid)"
        else
            info "Stopping Flutter (PID $flutter_pid)..."
            kill "$flutter_pid" 2>/dev/null || true
            sleep 1
            pid_alive "$flutter_pid" && kill -9 "$flutter_pid" 2>/dev/null || true
            rm -f "$FLUTTER_PID_FILE"
            success "Flutter stopped"
        fi
    else
        # Fall back: kill whatever holds the UI port.
        local port_pid
        port_pid="$(lsof -ti ":$UI_PORT" 2>/dev/null || true)"
        if [[ -n "$port_pid" ]]; then
            if [[ "$DRYRUN" == true ]]; then
                dry "kill process on port $UI_PORT (PID $port_pid)"
            else
                info "Stopping process on port $UI_PORT (PID $port_pid)..."
                kill "$port_pid" 2>/dev/null || true
                success "Port $UI_PORT process stopped"
            fi
        else
            info "Flutter: not running"
        fi
        [[ "$DRYRUN" == false ]] && rm -f "$FLUTTER_PID_FILE"
    fi

    echo ""
    [[ "$DRYRUN" == true ]] && info "Dry run complete — nothing was stopped." || success "All NyxForge processes stopped."
}

# ---------------------------------------------------------------------------
# START
# ---------------------------------------------------------------------------
do_start() {
    # Build node args
    NODE_ARGS=(--testnet)
    [[ "$MAINNET" == true ]] && NODE_ARGS=()
    [[ "$MINE"    == true ]] && NODE_ARGS+=(--mine-on-start --mine-threads "$THREADS")

    echo ""
    info "NyxForge starting"
    [[ "$DRYRUN" == true ]] && warn "Dry run — nothing will actually start"
    [[ "$MAINNET" == true ]] && info "Network: mainnet" || info "Network: testnet"
    [[ "$MINE"    == true ]] && info "Mining: enabled ($THREADS thread(s))" || info "Mining: disabled"
    echo ""

    # -- Verify tools ----------------------------------------------------------
    if [[ "$DRYRUN" == false ]]; then
        command -v cargo &>/dev/null || die "cargo not found — install Rust: https://rustup.rs"
        [[ -x "$FLUTTER" ]] || die "flutter not found at $FLUTTER — run ./scripts/install-flutter.sh"
    else
        dry "check cargo is installed"
        dry "check flutter is installed at $FLUTTER"
    fi

    # -- Build node ------------------------------------------------------------
    if [[ "$DRYRUN" == true ]]; then
        dry "cargo build -p nyxforge-node"
    else
        info "Building nyxforge-node..."
        cd "$SCRIPT_DIR"
        cargo build -p nyxforge-node 2>&1
    fi

    # -- Start node ------------------------------------------------------------
    if [[ "$DRYRUN" == true ]]; then
        dry "$NODE_BIN ${NODE_ARGS[*]:-} > $NODE_LOG 2>&1 &"
        dry "write PID to $NODE_PID_FILE"
    else
        info "Starting node (logs → $NODE_LOG)"
        "$NODE_BIN" "${NODE_ARGS[@]}" > "$NODE_LOG" 2>&1 &
        NODE_PID=$!
        echo "$NODE_PID" > "$NODE_PID_FILE"

        # Wait for RPC (up to 10 s)
        echo -n "    Waiting for RPC..."
        for i in $(seq 1 20); do
            if curl -sf -X POST "$RPC_URL" \
                    -H 'Content-Type: application/json' \
                    -d '{"method":"status","params":{}}' &>/dev/null; then
                echo " ready."
                break
            fi
            sleep 0.5
            echo -n "."
            if [[ $i -eq 20 ]]; then
                echo " timed out — check $NODE_LOG"
            fi
        done
    fi

    # -- Cleanup trap ----------------------------------------------------------
    cleanup() {
        echo ""
        info "Shutting down..."
        local pid
        pid="$(read_pid_file "$NODE_PID_FILE")"
        [[ -n "$pid" ]] && kill "$pid" 2>/dev/null || true
        rm -f "$NODE_PID_FILE" "$FLUTTER_PID_FILE"
    }
    trap cleanup INT TERM EXIT

    # -- Open browser ----------------------------------------------------------
    if [[ "$OPEN_BROWSER" == true && "$DRYRUN" == false ]]; then
        (sleep 8 && open -a "Google Chrome" "http://localhost:$UI_PORT") &
    elif [[ "$DRYRUN" == true ]]; then
        dry "open http://localhost:$UI_PORT in Chrome (after 8 s)"
    fi

    # -- Start Flutter ---------------------------------------------------------
    if [[ "$DRYRUN" == true ]]; then
        dry "flutter run -d chrome --web-port $UI_PORT  (foreground)"
        echo ""
        info "Dry run complete — nothing was started."
        return
    fi

    info "Starting Flutter UI..."
    cd "$SCRIPT_DIR/ui"
    "$FLUTTER" run -d chrome --web-port "$UI_PORT" &
    FLUTTER_PID=$!
    echo "$FLUTTER_PID" > "$FLUTTER_PID_FILE"

    # Wait for Flutter to exit (Ctrl-C triggers the cleanup trap).
    wait "$FLUTTER_PID" || true
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
case "$ACTION" in
    start) do_start ;;
    stop)  do_stop  ;;
esac
