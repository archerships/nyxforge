#!/usr/bin/env bash
# nyxforge — manage the NyxForge node and Flutter UI
#
# Usage:
#   ./nyxforge [ACTION] [OPTIONS]
#
# Actions:
#   --start         Build and start node + Flutter UI (default if no action given)
#   --stop          Stop all running NyxForge processes
#   --status        Show status of all NyxForge processes
#   --help          Show this message and exit
#
# Options (for --start):
#   --mine              Start mining immediately at launch
#   --threads <n>       CPU threads for mining (default: 1)
#   --pool <host:port>  Stratum endpoint to mine against (default: 127.0.0.1:3333)
#   --mainnet           Use mainnet instead of testnet
#   --no-browser        Don't open Chrome automatically
#   --wallet-key <hex>  Import existing wallet from XMR spend key (64-char hex);
#                       if omitted a fresh wallet is generated automatically
#
# Modifiers:
#   --dryrun            Show what would be done without doing it
#
# Examples:
#   ./nyxforge                            # start on testnet
#   ./nyxforge --start --mine --threads 4
#   ./nyxforge --stop
#   ./nyxforge --stop --dryrun
#   ./nyxforge --start --mainnet --dryrun
#   ./nyxforge --status

set -euo pipefail

# ---------------------------------------------------------------------------
# Colours
# ---------------------------------------------------------------------------
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info()    { echo -e "${CYAN}[nyxforge]${RESET} $*"; }
success() { echo -e "${GREEN}[nyxforge]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[nyxforge]${RESET} $*"; }
die()     { echo -e "${RED}[nyxforge] ERROR:${RESET} $*" >&2; exit 1; }
dry()     { echo -e "${YELLOW}[dryrun]${RESET}   $*"; }

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
export PATH="$HOME/.cargo/bin:$HOME/development/flutter/bin:$PATH"
FLUTTER="${FLUTTER:-$HOME/development/flutter/bin/flutter}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NODE_BIN="$SCRIPT_DIR/target/debug/nyxforge-node"
NODE_LOG="$SCRIPT_DIR/node.log"
NODE_PID_FILE="$SCRIPT_DIR/node.pid"
FLUTTER_PID_FILE="$SCRIPT_DIR/flutter.pid"
RPC_URL="http://127.0.0.1:8888/rpc"
UI_PORT=8080

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
ACTION=""
DRYRUN=false
MINE=false
THREADS=1
POOL_URL=""
MAINNET=false
OPEN_BROWSER=true
WALLET_KEY=""

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------
usage() {
    # Print the header comment block at the top of the file, stopping at the
    # first line that isn't a comment (i.e. the first real code line).
    awk '/^[^#]/ && NR > 1 { exit } /^#!/ { next } { sub(/^# ?/, ""); print }' \
        "${BASH_SOURCE[0]}"
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --start)      ACTION=start ;;
        --stop)       ACTION=stop ;;
        --status)     ACTION=status ;;
        --help|-h)    usage ;;
        --dryrun)     DRYRUN=true ;;
        --mine)       MINE=true ;;
        --mainnet)    MAINNET=true ;;
        --threads)
            [[ $# -ge 2 ]] || die "--threads requires a value"
            THREADS="$2"; shift ;;
        --no-browser) OPEN_BROWSER=false ;;
        --pool)
            [[ $# -ge 2 ]] || die "--pool requires a value (e.g. 127.0.0.1:3333)"
            POOL_URL="$2"; shift ;;
        --wallet-key)
            [[ $# -ge 2 ]] || die "--wallet-key requires a value"
            WALLET_KEY="$2"; shift ;;
        *) die "Unknown option: $1  (run with --help for usage)" ;;
    esac
    shift
done

# Default action is --start
[[ -z "$ACTION" ]] && ACTION=start

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Run or describe a command based on --dryrun.
run() {
    if [[ "$DRYRUN" == true ]]; then
        dry "$*"
    else
        "$@"
    fi
}

pid_alive() {
    local pid="$1"
    kill -0 "$pid" 2>/dev/null
}

read_pid_file() {
    local file="$1"
    [[ -f "$file" ]] && cat "$file" || true
}

stop_pid() {
    local name="$1"
    local pid_file="$2"
    local pid
    pid="$(read_pid_file "$pid_file")"

    if [[ -z "$pid" ]]; then
        info "$name: no PID file found, checking by name..."
        pid="$(pgrep -x "$name" 2>/dev/null || true)"
    fi

    if [[ -z "$pid" ]]; then
        info "$name: not running"
        return
    fi

    if ! pid_alive "$pid"; then
        info "$name (PID $pid): already stopped"
        [[ "$DRYRUN" == false ]] && rm -f "$pid_file"
        return
    fi

    if [[ "$DRYRUN" == true ]]; then
        dry "kill $name (PID $pid)"
        return
    fi

    info "Stopping $name (PID $pid)..."
    kill "$pid" 2>/dev/null || true

    # Wait up to 5 s for graceful exit, then SIGKILL.
    for _ in $(seq 1 10); do
        pid_alive "$pid" || break
        sleep 0.5
    done
    if pid_alive "$pid"; then
        warn "$name did not exit — sending SIGKILL"
        kill -9 "$pid" 2>/dev/null || true
    fi

    rm -f "$pid_file"
    success "$name stopped"
}

# ---------------------------------------------------------------------------
# STOP
# ---------------------------------------------------------------------------
do_stop() {
    echo ""
    info "Stopping NyxForge..."
    [[ "$DRYRUN" == true ]] && warn "Dry run — nothing will be killed"

    stop_pid "nyxforge-node" "$NODE_PID_FILE"

    # Flutter's process name varies; use PID file first, fall back to port.
    local flutter_pid
    flutter_pid="$(read_pid_file "$FLUTTER_PID_FILE")"

    if [[ -n "$flutter_pid" ]] && pid_alive "$flutter_pid"; then
        if [[ "$DRYRUN" == true ]]; then
            dry "kill flutter (PID $flutter_pid)"
        else
            info "Stopping Flutter (PID $flutter_pid)..."
            kill "$flutter_pid" 2>/dev/null || true
            sleep 1
            pid_alive "$flutter_pid" && kill -9 "$flutter_pid" 2>/dev/null || true
            rm -f "$FLUTTER_PID_FILE"
            success "Flutter stopped"
        fi
    else
        # Fall back: kill whatever holds the UI port.
        local port_pid
        port_pid="$(lsof -ti ":$UI_PORT" 2>/dev/null || true)"
        if [[ -n "$port_pid" ]]; then
            if [[ "$DRYRUN" == true ]]; then
                dry "kill process on port $UI_PORT (PID $port_pid)"
            else
                info "Stopping process on port $UI_PORT (PID $port_pid)..."
                kill "$port_pid" 2>/dev/null || true
                success "Port $UI_PORT process stopped"
            fi
        else
            info "Flutter: not running"
        fi
        [[ "$DRYRUN" == false ]] && rm -f "$FLUTTER_PID_FILE"
    fi

    echo ""
    [[ "$DRYRUN" == true ]] && info "Dry run complete — nothing was stopped." || success "All NyxForge processes stopped."
}

# ---------------------------------------------------------------------------
# START
# ---------------------------------------------------------------------------
do_start() {
    # Build node args
    NODE_ARGS=(--testnet)
    [[ "$MAINNET"    == true ]] && NODE_ARGS=()
    [[ "$MINE"       == true ]] && NODE_ARGS+=(--mine-on-start --mine-threads "$THREADS")
    [[ -n "$POOL_URL"        ]] && NODE_ARGS+=(--p2pool-url "$POOL_URL")

    echo ""
    info "NyxForge starting"
    [[ "$DRYRUN" == true ]] && warn "Dry run — nothing will actually start"
    [[ "$MAINNET" == true ]] && info "Network: mainnet" || info "Network: stagenet"
    if [[ "$MINE" == true ]]; then
        pool_display="${POOL_URL:-127.0.0.1:3333}"
        info "Mining: enabled ($THREADS thread(s)) → ${pool_display}"
    else
        info "Mining: disabled  (use --mine to enable)"
    fi
    echo ""

    # -- Verify tools ----------------------------------------------------------
    if [[ "$DRYRUN" == false ]]; then
        command -v cargo &>/dev/null || die "cargo not found — install Rust: https://rustup.rs"
        [[ -x "$FLUTTER" ]] || die "flutter not found at $FLUTTER — run ./scripts/install-flutter.sh"
    else
        dry "check cargo is installed"
        dry "check flutter is installed at $FLUTTER"
    fi

    # -- Build node ------------------------------------------------------------
    if [[ "$DRYRUN" == true ]]; then
        dry "cargo build -p nyxforge-node"
    else
        info "Building nyxforge-node..."
        cd "$SCRIPT_DIR"
        cargo build -p nyxforge-node 2>&1
    fi

    # -- Start node ------------------------------------------------------------
    if [[ "$DRYRUN" == true ]]; then
        dry "$NODE_BIN ${NODE_ARGS[*]:-} > $NODE_LOG 2>&1 &"
        dry "write PID to $NODE_PID_FILE"
    else
        info "Starting node (logs → $NODE_LOG)"
        "$NODE_BIN" "${NODE_ARGS[@]}" > "$NODE_LOG" 2>&1 &
        NODE_PID=$!
        echo "$NODE_PID" > "$NODE_PID_FILE"

        # Wait for RPC (up to 10 s)
        echo -n "    Waiting for RPC..."
        for i in $(seq 1 20); do
            if curl -sf -X POST "$RPC_URL" \
                    -H 'Content-Type: application/json' \
                    -d '{"method":"status","params":{}}' &>/dev/null; then
                echo " ready."
                break
            fi
            sleep 0.5
            echo -n "."
            if [[ $i -eq 20 ]]; then
                echo " timed out — check $NODE_LOG"
            fi
        done
    fi

    # -- Wallet setup ----------------------------------------------------------
    if [[ "$DRYRUN" == false ]]; then
        # Check if wallet already exists.
        # Helper: extract a field from the RPC result envelope {"result": {...}}
        rpc_field() { python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result',{}).get('$1',''))" 2>/dev/null || true; }
        rpc_ok()    { python3 -c "import sys,json; d=json.load(sys.stdin); r=d.get('result',{}); exit(0 if any(r.values()) else 1)" 2>/dev/null; }

        wallet_check=$(curl -sf --max-time 2 -X POST "$RPC_URL" \
            -H 'Content-Type: application/json' \
            -d '{"method":"wallet.addresses","params":{}}' 2>/dev/null || true)
        wallet_exists=false
        if echo "$wallet_check" | python3 -c \
            "import sys,json; d=json.load(sys.stdin); exit(0 if d.get('result',{}).get('xmr') else 1)" 2>/dev/null; then
            wallet_exists=true
        fi

        if [[ "$wallet_exists" == true ]]; then
            xmr_full=$(echo "$wallet_check" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['result']['xmr'])" 2>/dev/null || echo "?")
            xmr_addr="${xmr_full:0:8}...${xmr_full: -6}"
            info "Wallet loaded from disk  (XMR ${xmr_addr})"
        elif [[ -n "$WALLET_KEY" ]]; then
            info "Importing wallet from provided spend key..."
            result=$(curl -sf -X POST "$RPC_URL" \
                -H 'Content-Type: application/json' \
                -d "{\"method\":\"wallet.import\",\"params\":{\"spend_key\":\"${WALLET_KEY}\"}}" 2>/dev/null || true)
            xmr_full=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result',{}).get('xmr_address',''))" 2>/dev/null || echo "")
            if [[ -n "$xmr_full" ]]; then
                xmr_addr="${xmr_full:0:8}...${xmr_full: -6}"
                success "Wallet imported  (XMR ${xmr_addr})"
            else
                warn "Wallet import failed: ${result}"
            fi
        else
            info "No wallet found — generating new wallet..."
            result=$(curl -sf -X POST "$RPC_URL" \
                -H 'Content-Type: application/json' \
                -d '{"method":"wallet.create","params":{"passphrase":""}}' 2>/dev/null || true)
            xmr_full=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result',{}).get('xmr_address',''))" 2>/dev/null || echo "")
            if [[ -n "$xmr_full" ]]; then
                xmr_addr="${xmr_full:0:8}...${xmr_full: -6}"
                spend_key=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result',{}).get('xmr_spend_key',''))" 2>/dev/null || echo "")
                success "Wallet created  (XMR ${xmr_addr})"
                if [[ -n "$spend_key" ]]; then
                    echo ""
                    warn "SAVE YOUR SPEND KEY — needed to restore your wallet:"
                    echo -e "    ${BOLD}${spend_key}${RESET}"
                    echo ""
                fi
            else
                warn "Wallet creation failed: ${result}"
            fi
        fi
    else
        if [[ -n "$WALLET_KEY" ]]; then
            dry "wallet.import spend_key=${WALLET_KEY:0:8}..."
        else
            dry "wallet.create (generate new wallet)"
        fi
    fi

    # -- Cleanup trap ----------------------------------------------------------
    cleanup() {
        echo ""
        info "Shutting down..."
        local pid
        pid="$(read_pid_file "$NODE_PID_FILE")"
        [[ -n "$pid" ]] && kill "$pid" 2>/dev/null || true
        rm -f "$NODE_PID_FILE" "$FLUTTER_PID_FILE"
    }
    trap cleanup INT TERM EXIT

    # -- Open browser ----------------------------------------------------------
    if [[ "$OPEN_BROWSER" == true && "$DRYRUN" == false ]]; then
        (sleep 8 && open -a "Google Chrome" "http://localhost:$UI_PORT") &
    elif [[ "$DRYRUN" == true ]]; then
        dry "open http://localhost:$UI_PORT in Chrome (after 8 s)"
    fi

    # -- Start Flutter ---------------------------------------------------------
    if [[ "$DRYRUN" == true ]]; then
        dry "flutter run -d chrome --web-port $UI_PORT  (foreground)"
        echo ""
        info "Dry run complete — nothing was started."
        return
    fi

    info "Starting Flutter UI..."
    cd "$SCRIPT_DIR/ui"
    "$FLUTTER" run -d chrome --web-port "$UI_PORT" &
    FLUTTER_PID=$!
    echo "$FLUTTER_PID" > "$FLUTTER_PID_FILE"

    # Wait for Flutter to exit (Ctrl-C triggers the cleanup trap).
    wait "$FLUTTER_PID" || true
}

# ---------------------------------------------------------------------------
# STATUS
# ---------------------------------------------------------------------------
do_status() {
    local RULE
    RULE="$(printf '%.0s─' {1..52})"

    # -- helpers ---------------------------------------------------------------

    # Print a status row: label, indicator, detail
    status_row() {
        local label="$1" indicator="$2" detail="$3"
        printf "  ${BOLD}%-14s${RESET}  %s  %s\n" "$label" "$indicator" "$detail"
    }

    ok()   { echo -e "${GREEN}●${RESET}"; }
    dead() { echo -e "${RED}○${RESET}"; }

    # Human-readable elapsed time from ps (format: [[DD-]HH:]MM:SS)
    uptime_for_pid() {
        local pid="$1"
        ps -o etime= -p "$pid" 2>/dev/null | tr -d ' ' || echo "?"
    }

    # Call the local RPC and return the JSON result field, or empty on failure.
    rpc_call() {
        local method="$1"
        curl -sf --max-time 2 -X POST "$RPC_URL" \
            -H 'Content-Type: application/json' \
            -d "{\"method\":\"${method}\",\"params\":{}}" 2>/dev/null || true
    }

    # Parse a JSON field from a string using python3.
    json_get() {
        local json="$1" key="$2"
        echo "$json" | python3 -c \
            "import sys,json; d=json.load(sys.stdin); print(d.get('$key',''))" \
            2>/dev/null || true
    }

    # -- header ----------------------------------------------------------------
    echo ""
    echo -e "${BOLD}NyxForge status${RESET}  $(date '+%Y-%m-%d %H:%M:%S')"
    echo "$RULE"

    # -- node ------------------------------------------------------------------
    local node_pid node_detail node_ind
    node_pid="$(read_pid_file "$NODE_PID_FILE")"
    if [[ -z "$node_pid" ]]; then
        node_pid="$(pgrep -x nyxforge-node 2>/dev/null | head -1 || true)"
    fi

    if [[ -n "$node_pid" ]] && pid_alive "$node_pid"; then
        node_ind="$(ok)"
        node_detail="running   PID ${node_pid}   up $(uptime_for_pid "$node_pid")"
    else
        node_ind="$(dead)"
        node_detail="stopped"
        node_pid=""
    fi
    status_row "node" "$node_ind" "$node_detail"

    # -- Flutter UI ------------------------------------------------------------
    local flutter_pid flutter_detail flutter_ind
    flutter_pid="$(read_pid_file "$FLUTTER_PID_FILE")"
    if [[ -n "$flutter_pid" ]] && pid_alive "$flutter_pid"; then
        flutter_ind="$(ok)"
        flutter_detail="running   PID ${flutter_pid}   port ${UI_PORT}   up $(uptime_for_pid "$flutter_pid")"
    else
        # Fall back: any process holding the UI port
        local port_pid
        port_pid="$(lsof -ti ":$UI_PORT" 2>/dev/null | head -1 || true)"
        if [[ -n "$port_pid" ]]; then
            flutter_ind="$(ok)"
            flutter_detail="running   PID ${port_pid}   port ${UI_PORT}"
        else
            flutter_ind="$(dead)"
            flutter_detail="stopped"
        fi
    fi
    status_row "Flutter UI" "$flutter_ind" "$flutter_detail"

    # -- RPC -------------------------------------------------------------------
    local rpc_ind rpc_detail rpc_resp
    rpc_resp="$(rpc_call status)"
    if [[ -n "$rpc_resp" ]]; then
        rpc_ind="$(ok)"
        rpc_detail="reachable   ${RPC_URL}"
    else
        rpc_ind="$(dead)"
        rpc_detail="unreachable   ${RPC_URL}"
    fi
    status_row "RPC" "$rpc_ind" "$rpc_detail"

    echo "$RULE"

    # -- miner (via RPC) -------------------------------------------------------
    local miner_ind miner_detail miner_resp
    miner_resp="$(rpc_call miner.status)"
    if [[ -n "$miner_resp" ]]; then
        local running hashrate shares
        running="$(json_get "$miner_resp" running)"
        hashrate="$(json_get "$miner_resp" hashrate_h_s)"
        shares="$(json_get  "$miner_resp" shares_found)"
        if [[ "$running" == "True" || "$running" == "true" ]]; then
            miner_ind="$(ok)"
            # Format hashrate: show kH/s if ≥ 1000
            local hr_display
            hr_display="$(python3 -c "
h = float('${hashrate}' or 0)
print(f'{h/1000:.2f} kH/s' if h >= 1000 else f'{h:.1f} H/s')
" 2>/dev/null || echo "${hashrate} H/s")"
            miner_detail="mining    ${hr_display}   ${shares} share(s)"
        else
            miner_ind="$(dead)"
            miner_detail="stopped"
        fi
    else
        miner_ind="${YELLOW}?${RESET}"
        miner_detail="unknown (node not reachable)"
    fi
    status_row "miner" "$miner_ind" "$miner_detail"

    # -- wallet (via RPC) ------------------------------------------------------
    local wallet_ind wallet_detail wallet_resp
    wallet_resp="$(rpc_call wallet.addresses)"
    if [[ -n "$wallet_resp" ]]; then
        local xmr_addr
        xmr_addr="$(json_get "$wallet_resp" xmr)"
        if [[ -n "$xmr_addr" && "$xmr_addr" != "None" && "$xmr_addr" != "null" ]]; then
            # Show first 8 … last 6 chars of the address
            local short_addr
            short_addr="$(echo "$xmr_addr" | python3 -c \
                "import sys; a=sys.stdin.read().strip(); print(a[:8]+'…'+a[-6:])" \
                2>/dev/null || echo "$xmr_addr")"
            wallet_ind="$(ok)"
            wallet_detail="created   XMR ${short_addr}"
        else
            wallet_ind="$(dead)"
            wallet_detail="not created   (run: curl -X POST $RPC_URL -d '{\"method\":\"wallet.create\",\"params\":{\"passphrase\":\"\"}}')"
        fi
    else
        wallet_ind="${YELLOW}?${RESET}"
        wallet_detail="unknown (node not reachable)"
    fi
    status_row "wallet" "$wallet_ind" "$wallet_detail"

    echo "$RULE"
    echo ""
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
case "$ACTION" in
    start)  do_start  ;;
    stop)   do_stop   ;;
    status) do_status ;;
esac
